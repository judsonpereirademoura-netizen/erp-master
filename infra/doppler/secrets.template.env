# ============================================================
# ERP MASTER v2.0 — Doppler Secrets Configuration
# Configurar em: https://dashboard.doppler.com
# Projeto: erp-master
# ============================================================
#
# COMO CONFIGURAR:
# 1. Acesse dashboard.doppler.com
# 2. Crie o projeto "erp-master"
# 3. Crie os ambientes: development, staging, production
# 4. Adicione cada secret abaixo no ambiente correspondente
# 5. No Vercel, instale a integração Doppler e vincule ao projeto
# 6. Secrets serão injetados automaticamente no build e runtime
#
# NUNCA commitar valores reais — este arquivo é apenas o template
# ============================================================

# ─── SUPABASE ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...         # NUNCA expor no frontend
SUPABASE_JWT_SECRET=seu-jwt-secret       # Dashboard Supabase > Settings > API
DATABASE_URL=postgresql://postgres:senha@db.SEU_PROJECT_ID.supabase.co:5432/postgres

# ─── AUTENTICAÇÃO ─────────────────────────────────────────────────────────────
NEXTAUTH_SECRET=gere-com-openssl-rand-base64-32
NEXTAUTH_URL=https://erp.masteretiquetas.com

# URLs de cada portal (usadas nos redirects de auth)
AUTH_URL_ERP=https://erp.masteretiquetas.com
AUTH_URL_ECOMMERCE=https://masteretiquetas.com
AUTH_URL_CLIENTE=https://cliente.masteretiquetas.com
AUTH_URL_REPRESENTANTE=https://representante.masteretiquetas.com
AUTH_URL_FORNECEDOR=https://fornecedor.masteretiquetas.com

# ─── CLAUDE AI (Anthropic) ────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-5-20251001

# ─── ZAPCONNECT (whatsapp.masteretiquetas.com) ────────────────────────────────
ZAPCONNECT_API_URL=https://whatsapp.masteretiquetas.com
ZAPCONNECT_API_KEY=sua-api-key-interna
ZAPCONNECT_WEBHOOK_SECRET=segredo-hmac-sha256   # para validar webhooks recebidos
META_WEBHOOK_SECRET=segredo-da-meta             # X-Hub-Signature-256

# ─── TELEGRAM BOT (CEO) ───────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=1234567890:AAF...
TELEGRAM_CEO_CHAT_ID=123456789        # chat_id do CEO (obter via @userinfobot)
TELEGRAM_WEBHOOK_SECRET=segredo-validacao

# ─── SEFAZ (NF-e) ─────────────────────────────────────────────────────────────
SEFAZ_AMBIENTE=2                      # 1=producao, 2=homologacao
SEFAZ_CERTIFICADO_PFX_BASE64=base64-do-certificado-A1
SEFAZ_CERTIFICADO_SENHA=senha-do-certificado
EMITENTE_CNPJ=00000000000000
EMITENTE_RAZAO_SOCIAL=MASTER ROTULOS E ETIQUETAS LTDA
EMITENTE_IE=0000000000000
EMITENTE_UF=GO

# ─── PIX ──────────────────────────────────────────────────────────────────────
PIX_CHAVE=cnpj-ou-email-ou-aleatoria
PIX_BANCO=seu-banco                   # inter, bradesco, itau, etc.
PIX_CLIENT_ID=client-id-do-banco
PIX_CLIENT_SECRET=client-secret-do-banco
PIX_CERTIFICADO_PEM=base64-certificado-mtls

# ─── AWS S3 (backup offsite) ──────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=sa-east-1                  # São Paulo
AWS_S3_BACKUP_BUCKET=erp-master-backup-prod

# ─── CLOUDFLARE ───────────────────────────────────────────────────────────────
CLOUDFLARE_API_TOKEN=seu-token
CLOUDFLARE_ZONE_ID=zone-id-masteretiquetas-com
CLOUDFLARE_ACCOUNT_ID=account-id

# ─── SENTRY ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN=https://xxx@xxx.ingest.sentry.io/xxx
SENTRY_AUTH_TOKEN=sntrys_...
SENTRY_ORG=master-rotulos
SENTRY_PROJECT=erp-master

# ─── BETTER STACK (Logtail) ───────────────────────────────────────────────────
LOGTAIL_SOURCE_TOKEN=seu-token

# ─── MQTT (IoT) ───────────────────────────────────────────────────────────────
MQTT_BROKER_URL=mqtt://seu-broker:1883
MQTT_USERNAME=erp-master
MQTT_PASSWORD=senha-mqtt
MQTT_TLS=true

# ─── DOPPLER (referência — não é secret) ──────────────────────────────────────
# doppler setup --project erp-master --config production
# doppler run -- node server.js
